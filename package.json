{
  "name": "waliya-management-platform",
  "version": "1.0.0",
  "description": "Waliya — offline game management for agents and admins (Windows 8+)",
  "author": "Waliya",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "setup": "npm install && npm run build:electron && npm run rebuild:native",
    "postinstall": "npm run build:electron && npm run rebuild:native",
    "rebuild:native": "electron-builder install-app-deps",
    "start": "npm run desktop:dev",
    "dev": "npm run desktop:dev",
    "web": "node scripts/dev-web.mjs",
    "electron:only": "npm run build:electron && node scripts/launch-electron.mjs",
    "start:manual": "echo Run 'npm run web' in one terminal, then 'npm run electron:only' in another",
    "dev:next": "npm run web",
    "desktop:dev": "npm run build:electron && concurrently -k -n NEXT,ELECTRON -c blue,magenta \"npm run dev:next\" \"npm run dev:electron\"",
    "dev:electron": "node scripts/wait-for-next.mjs && node scripts/launch-electron.mjs",
    "build": "npm run build:next && npm run build:electron",
    "build:next": "cross-env NODE_ENV=production next build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "clean:build": "node scripts/clean-build.mjs",
    "generate:icon": "node scripts/generate-app-icon.mjs",
    "desktop": "npm run build && cross-env NODE_ENV=production electron .",
    "dist:win": "node scripts/pack-win.mjs",
    "pack:win": "node scripts/pack-win.mjs",
    "test": "playwright test",
    "test:smoke": "node scripts/smoke-test.mjs",
    "generate:amharic-audio": "node scripts/generate-amharic-audio.mjs",
    "recording:script": "node scripts/print-recording-script.mjs",
    "validate:audio": "node scripts/validate-custom-audio.mjs",
    "validate:release": "node scripts/validate-release.mjs",
    "test:cross-pc": "node scripts/test-cross-pc-flow.mjs",
    "test:calling-engine": "npx tsx scripts/test-calling-engine.mjs",
    "test:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.4",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "9.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.3",
    "electron-store": "^8.2.0",
    "lucide-react": "^0.469.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.6.0",
    "uuid": "^11.0.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.30.1",
    "electron": "22.3.27",
    "electron-builder": "24.13.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.1.3",
    "playwright": "^1.60.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "browserslist": [
    "chrome >= 108"
  ]
}
